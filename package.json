{
  "name": "opensquid",
  "version": "0.6.4",
  "description": "The MCP server that decides which of your agent's memories survive. Powered by loop-engine.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opensquid": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "memory",
    "verification",
    "anti-self-grading",
    "loop-engine",
    "mindcraftor"
  ],
  "author": "Sangmin Lee <sangmlee23@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smlee/opensquid.git"
  },
  "bugs": {
    "url": "https://github.com/smlee/opensquid/issues"
  },
  "homepage": "https://opensquid.tools",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.16.0",
    "discord.js": "^14.26.4",
    "grammy": "^1.42.0",
    "opensquid-engine-darwin-arm64": "0.6.0",
    "opensquid-engine-darwin-x64": "0.6.0",
    "opensquid-engine-linux-arm64": "0.6.0",
    "opensquid-engine-linux-x64": "0.6.0",
    "opensquid-engine-win32-arm64": "0.6.0",
    "opensquid-engine-win32-x64": "0.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
