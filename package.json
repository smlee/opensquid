{
  "name": "opensquid",
  "version": "0.5.85",
  "description": "Tracks for your AI agent — destination-first.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "opensquid": "./dist/cli.js",
    "opensquid-hook-pretooluse": "./dist/runtime/hooks/pre-tool-use.js",
    "opensquid-hook-sessionend": "./dist/runtime/hooks/session-end.js",
    "opensquid-hook-stop": "./dist/runtime/hooks/stop.js",
    "opensquid-hook-userpromptsubmit": "./dist/runtime/hooks/user-prompt-submit.js",
    "opensquid-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "schemas",
    "packs/builtin"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "schemas": "tsx scripts/emit-schemas.ts",
    "prepublishOnly": "pnpm schemas && pnpm build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "memory",
    "verification",
    "anti-self-grading",
    "loop-engine",
    "mindcraftor"
  ],
  "author": "Sangmin Lee <sangmlee23@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smlee/opensquid.git"
  },
  "bugs": {
    "url": "https://github.com/smlee/opensquid/issues"
  },
  "homepage": "https://opensquid.tools",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "grammy": "^1.43.0",
    "lru-cache": "^11.5.0",
    "minimatch": "^10.0.0",
    "mustache": "^4.2.0",
    "node-cron": "^3.0.3",
    "picocolors": "^1.0.0",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.6.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.6",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/proper-lockfile": "^4.1.4",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "ajv": "^8.20.0",
    "eslint": "^9.10.0",
    "eslint-plugin-import": "^2.30.0",
    "prettier": "^3.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^2.0.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "@slack/socket-mode": "^2.0.0",
    "@slack/web-api": "^7.0.0",
    "discord.js": "^14.16.0",
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@slack/socket-mode": {
      "optional": true
    },
    "@slack/web-api": {
      "optional": true
    },
    "discord.js": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  }
}
