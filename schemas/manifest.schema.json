{
  "$ref": "#/definitions/manifest",
  "definitions": {
    "manifest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+"
        },
        "scope": {
          "type": "string",
          "enum": ["universal", "domain", "specialty", "workflow", "project"]
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "extends": {
          "type": "string"
        },
        "evolves": {
          "type": "boolean",
          "default": true
        }
      },
      "required": ["name", "version", "scope", "goal"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
