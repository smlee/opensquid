{
  "$ref": "#/definitions/skill",
  "definitions": {
    "skill": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "load": {
          "type": "string",
          "enum": [
            "preload",
            "lazy"
          ],
          "default": "lazy"
        },
        "when_to_load": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "tool_match"
                  },
                  "tool": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "kind",
                  "tool"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "command_pattern"
                  },
                  "pattern": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "kind",
                  "pattern"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "file_glob"
                  },
                  "glob": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "kind",
                  "glob"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "event_type"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "tool_call",
                      "post_tool_call",
                      "prompt_submit",
                      "session_end",
                      "stop",
                      "session_start",
                      "schedule",
                      "webhook",
                      "inbound_channel",
                      "file_changed"
                    ]
                  }
                },
                "required": [
                  "kind",
                  "type"
                ],
                "additionalProperties": false
              }
            ]
          },
          "default": []
        },
        "requires": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "automation_mode_on"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "active_task_present"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              }
            ]
          },
          "default": []
        },
        "unloads_when": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "active_task_completes"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "session_ends"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "idle_n_turns"
                  },
                  "n": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  }
                },
                "required": [
                  "kind",
                  "n"
                ],
                "additionalProperties": false
              }
            ]
          },
          "default": []
        },
        "triggers": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "tool_call"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "post_tool_call"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "prompt_submit"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "session_end"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "stop"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "session_start"
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "schedule"
                  },
                  "cron": {
                    "type": "string"
                  },
                  "cost_tier": {
                    "type": "string",
                    "enum": [
                      "cheap",
                      "balanced",
                      "premium"
                    ]
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "webhook"
                  },
                  "path": {
                    "type": "string"
                  },
                  "cost_tier": {
                    "type": "string",
                    "enum": [
                      "cheap",
                      "balanced",
                      "premium"
                    ]
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "inbound_channel"
                  },
                  "channel": {
                    "type": "string"
                  },
                  "sender_pattern": {
                    "type": "string"
                  },
                  "cost_tier": {
                    "type": "string",
                    "enum": [
                      "cheap",
                      "balanced",
                      "premium"
                    ]
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "file_changed"
                  },
                  "paths": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "ignored": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "cost_tier": {
                    "type": "string",
                    "enum": [
                      "cheap",
                      "balanced",
                      "premium"
                    ]
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              }
            ]
          },
          "minItems": 1,
          "default": [
            {
              "kind": "tool_call"
            }
          ]
        },
        "rules": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kind": {
                    "type": "string",
                    "const": "track_check",
                    "default": "track_check"
                  },
                  "requires": {
                    "type": "array",
                    "items": {
                      "anyOf": [
                        {
                          "type": "object",
                          "properties": {
                            "kind": {
                              "type": "string",
                              "const": "automation_mode_on"
                            }
                          },
                          "required": [
                            "kind"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "kind": {
                              "type": "string",
                              "const": "active_task_present"
                            }
                          },
                          "required": [
                            "kind"
                          ],
                          "additionalProperties": false
                        }
                      ]
                    },
                    "default": []
                  },
                  "process": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "call": {
                          "type": "string",
                          "minLength": 1
                        },
                        "args": {
                          "type": "object",
                          "additionalProperties": {}
                        },
                        "as": {
                          "type": "string"
                        },
                        "if": {
                          "type": "string"
                        },
                        "on_empty": {
                          "type": "string",
                          "enum": [
                            "pass",
                            "block",
                            "continue"
                          ]
                        },
                        "on_error": {
                          "type": "string",
                          "enum": [
                            "abort",
                            "continue"
                          ]
                        }
                      },
                      "required": [
                        "call"
                      ],
                      "additionalProperties": false
                    },
                    "minItems": 1
                  }
                },
                "required": [
                  "id",
                  "process"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kind": {
                    "type": "string",
                    "const": "destination_check"
                  },
                  "interval": {
                    "type": "object",
                    "properties": {
                      "every_n_tool_calls": {
                        "type": "integer",
                        "exclusiveMinimum": 0
                      }
                    },
                    "required": [
                      "every_n_tool_calls"
                    ],
                    "additionalProperties": false
                  },
                  "model_alias": {
                    "type": "string",
                    "default": "reasoning"
                  },
                  "prompt_template": {
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "kind",
                  "interval",
                  "prompt_template"
                ],
                "additionalProperties": false
              }
            ]
          },
          "default": []
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "prose": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
