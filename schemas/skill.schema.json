{
  "$ref": "#/definitions/skill",
  "definitions": {
    "skill": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "load": {
          "type": "string",
          "enum": ["preload", "lazy"],
          "default": "lazy"
        },
        "when_to_load": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "tool_match"
                  },
                  "tool": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["kind", "tool"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "command_pattern"
                  },
                  "pattern": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["kind", "pattern"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "file_glob"
                  },
                  "glob": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["kind", "glob"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "event_type"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["tool_call", "prompt_submit", "stop", "session_end"]
                  }
                },
                "required": ["kind", "type"],
                "additionalProperties": false
              }
            ]
          },
          "default": []
        },
        "unloads_when": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "active_task_completes"
                  }
                },
                "required": ["kind"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "session_ends"
                  }
                },
                "required": ["kind"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "idle_n_turns"
                  },
                  "n": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  }
                },
                "required": ["kind", "n"],
                "additionalProperties": false
              }
            ]
          },
          "default": []
        },
        "rules": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kind": {
                    "type": "string",
                    "const": "track_check",
                    "default": "track_check"
                  },
                  "process": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "call": {
                          "type": "string",
                          "minLength": 1
                        },
                        "args": {
                          "type": "object",
                          "additionalProperties": {}
                        },
                        "as": {
                          "type": "string"
                        },
                        "if": {
                          "type": "string"
                        },
                        "on_empty": {
                          "type": "string",
                          "enum": ["pass", "block", "continue"]
                        }
                      },
                      "required": ["call"],
                      "additionalProperties": false
                    },
                    "minItems": 1
                  }
                },
                "required": ["id", "process"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kind": {
                    "type": "string",
                    "const": "destination_check"
                  },
                  "interval": {
                    "type": "object",
                    "properties": {
                      "every_n_tool_calls": {
                        "type": "integer",
                        "exclusiveMinimum": 0
                      }
                    },
                    "required": ["every_n_tool_calls"],
                    "additionalProperties": false
                  },
                  "model_alias": {
                    "type": "string",
                    "default": "reasoning"
                  },
                  "prompt_template": {
                    "type": "string"
                  }
                },
                "required": ["id", "kind", "interval", "prompt_template"],
                "additionalProperties": false
              }
            ]
          },
          "default": []
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "prose": {
          "type": "string"
        }
      },
      "required": ["name"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
